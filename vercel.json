{
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "https://api-capstone.thelunareix.my.id/api/v1/$1"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "build": {
    "env": {
      "BUILD_ENV": "production"
    }
  }
}
